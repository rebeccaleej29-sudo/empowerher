---
const { site } = Astro.props;
---
<div class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label={site.brand.name}>
      {site.brand.logo ? (
        <img class="brand-logo" src={site.brand.logo} alt={`${site.brand.name} logo`} loading="eager" />
      ) : (
        <span>{site.brand.name}</span>
      )}
    </a>
    <nav class="nav-links" aria-label="Primary">
      {site.nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</div>
