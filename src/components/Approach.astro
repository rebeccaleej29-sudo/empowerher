---
const { site } = Astro.props;
---
<section id="approach">
  <div class="container">
    <div class="section-head">
      <h2>{site.sections.approach.title}</h2>
      <span class="muted">Evidence-based strength training, personalised support</span>
    </div>
    <div class="grid" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
      {site.sections.approach.items.map((i) => (
        <div class="card"><h3>{i}</h3><p> </p></div>
      ))}
    </div>
  </div>
  <style>
    @media (max-width: 900px) { .grid { grid-template-columns: 1fr !important; } }
  </style>
</section>
