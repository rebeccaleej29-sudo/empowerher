---
const { site } = Astro.props;
const formName = site.contact.form?.netlifyFormName ?? 'contact';
const phoneDigits = site.contact.phone.replace(/[^0-9+]/g, '');
---
<section id="contact">
  <div class="container">
    <div class="section-head">
      <h2>{site.contact.title}</h2>
      <span class="muted">{site.contact.subtitle}</span>
    </div>
    <div class="contact-grid">
      <div class="card">
        <h3>Contact options</h3>
        <p style="margin-top:8px;">Phone: <a href={`tel:${phoneDigits}`}>{site.contact.phone}</a></p>
        <p>Email: <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
        <p>WhatsApp: <a href={site.contact.whatsapp.url} target="_blank" rel="noreferrer">{site.contact.whatsapp.number}</a></p>
        {site.contact.enquiryForm?.url ? (
          <p>Enquiry form: <a href={site.contact.enquiryForm.url} target="_blank" rel="noreferrer">Open form</a></p>
        ) : null}
        <div class="hero-actions" style="margin-top:14px;">
          <a class="btn primary" href={site.contact.whatsapp.url} target="_blank" rel="noreferrer">WhatsApp</a>
          <a class="btn" href={`mailto:${site.contact.email}?subject=EmpowerHer%20Booking%20Request`}>Email</a>
          {site.contact.enquiryForm?.url ? (
            <a class="btn" href={site.contact.enquiryForm.url} target="_blank" rel="noreferrer">Enquiry form</a>
          ) : null}
        </div>
        <p class="muted" style="margin-top:14px;">Prefer a quick note? Use the form below and we’ll reply as soon as possible.</p>
      </div>
      <div class="card">
        <h3>Send a message</h3>
        <form name={formName} method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks/">
          <input type="hidden" name="form-name" value={formName} />
          <p style="display:none;"><label>Don’t fill this out if you’re human: <input name="bot-field" /></label></p>
          <label><span class="muted">Name</span><input name="name" required /></label>
          <label><span class="muted">Email</span><input name="email" type="email" required /></label>
          <label><span class="muted">Message</span><textarea name="message" required></textarea></label>
          <button class="btn primary" type="submit">Send message</button>
          <p class="muted" style="font-size:0.92rem;">This form is powered by Netlify Forms — no extra backend needed.</p>
        </form>
      </div>
    </div>
  </div>
</section>
